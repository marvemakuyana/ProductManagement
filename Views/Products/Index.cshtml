@model IEnumerable<ProductManagement.Models.Product>

@{
    ViewData["Title"] = "Products";
}
<h2>Product Management</h2>

<div class="d-flex justify-content-end mb-3">
    <p>
        <a asp-action="Create" class="btn btn-primary">Add Product</a>
  
        <a asp-action="ExportExcel" class="btn btn-success">Download Excel</a>

        <a asp-action="UploadExcel" class="btn btn-warning">Upload Excel</a>

    </p>
</div>

@if (!Model.Any())
{
    <p class="text-center">No products found.</p>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Code</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Image</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductCode</td>
                <td>@item.Name</td>
                <td>@item.Category?.Name</td>
                <td>@item.Price.ToString("0.00")</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath"
                             width="60"
                             height="60"
                             style="object-fit:cover;"/>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-secondary">Edit</a>
                    <form asp-action="Delete" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.ProductId" />
                        <button type="submit" class="btn btn-danger" 
                                onclick="return confirm('Delete this product?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4 d-flex gap-2 align-items-center">

    <span>
        Page @ViewBag.CurrentPage of @ViewBag.TotalPages
    </span>

    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="Index"
           asp-route-page="@(ViewBag.CurrentPage - 1)"
           class="btn btn-outline-secondary btn-sm">Previous</a>
    }

    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="Index"
           asp-route-page="@(ViewBag.CurrentPage + 1)"
           class="btn btn-outline-primary btn-sm">Next</a>
    }

</div>